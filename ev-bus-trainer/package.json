{
  "name": "ev-bus-trainer",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "Interactive E-Bus systems flowchart trainer",
  "author": "EV Bus Trainer",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "desktop": "npm run build && electron .",
    "dist": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis portable",
    "icon": "node scripts/build-icon.mjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "afterPack": "scripts/after-pack.cjs",
    "appId": "com.switchmobility.evats",
    "productName": "EVATS (Electric Vehicle Architecture Training System)",
    "directories": {
      "output": "release-v1.3"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EVATS"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "electron": "^42.3.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "framer-motion": "^12.40.0",
    "globals": "^17.6.0",
    "lucide-react": "^1.16.0",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-zoom-pan-pinch": "^4.0.3",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  },
  "dependencies": {
    "three": "^0.185.1"
  }
}

# =============================================================================
# EVATS — Application-Layer .gitignore
# Environment-layer categorisation — do not reorder or merge sections.
# =============================================================================

# ---------------------------------------------------------------------------
# 1. DEPENDENCY DIRECTORIES
# ---------------------------------------------------------------------------
node_modules/
jspm_packages/

# ---------------------------------------------------------------------------
# 2. BUILD / DISTRIBUTION ARTIFACTS
# ---------------------------------------------------------------------------
dist/
build/
out/
*.deploy/

# ---------------------------------------------------------------------------
# 3. ENVIRONMENT VARIABLES & SECRETS
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key

# ---------------------------------------------------------------------------
# 4. SYSTEM & IDE METADATA
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*

# ---------------------------------------------------------------------------
# 5. DIAGNOSTIC LOG FILES
# ---------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# ---------------------------------------------------------------------------
# 6. HEAVYWEIGHT SOURCE CAD / 3D BACKUPS
#    (Only the optimised 722 kB production GLB is versioned.)
# ---------------------------------------------------------------------------
*.max
*.obj
*.fbx
*.blend

# ---------------------------------------------------------------------------
# 7. ELECTRON BUILDER ARTIFACTS (project-specific)
# ---------------------------------------------------------------------------
release/
release-v2/

# ---------------------------------------------------------------------------
# 8. LOCAL ARCHIVE — rollback scratchpad, not shipped
# ---------------------------------------------------------------------------
_archive/
